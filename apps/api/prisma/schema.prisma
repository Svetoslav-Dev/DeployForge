generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppStatus {
  stopped
  running
  error
  deploying
}

enum DeploymentStatus {
  pending
  running
  success
  failed
}

enum TriggerType {
  manual
  webhook
  system
}

enum LogLevel {
  info
  warn
  error
  debug
}

enum UserRole {
  admin
  viewer
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  passwordHash  String
  role          UserRole       @default(viewer)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AuthEventType {
  login_success
  login_failure
}

model AuthLog {
  id        String        @id @default(cuid())
  username  String
  event     AuthEventType
  ip        String
  userAgent String?
  os        String?
  browser   String?
  timestamp DateTime      @default(now())

  @@index([timestamp])
  @@index([username, timestamp])
}

model Application {
  id            String        @id @default(cuid())
  name          String        @unique
  description   String?
  dockerImage   String
  containerName String        @unique
  internalPort  Int
  externalPort  Int
  environment   Json          @default("{}")
  status        AppStatus     @default(stopped)
  webhookSecret String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  deployments   Deployment[]
}

model Deployment {
  id            String           @id @default(cuid())
  applicationId String
  status        DeploymentStatus @default(pending)
  triggerType   TriggerType      @default(manual)
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  summary       String?
  errorMessage  String?

  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  logs          DeploymentLog[]
}

model DeploymentLog {
  id           String     @id @default(cuid())
  deploymentId String
  level        LogLevel   @default(info)
  message      String
  timestamp    DateTime   @default(now())

  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, timestamp])
}
